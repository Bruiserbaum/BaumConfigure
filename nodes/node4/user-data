#cloud-config
# Node 4 — TuringPICompute4 (Raspberry Pi CM4, eMMC only, Swarm Worker)

hostname: TuringPICompute4
manage_etc_hosts: true

users:
  - name: ubuntu
    groups: [sudo, docker]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - REPLACE_WITH_SSH_PUBLIC_KEY
    # Uncomment to allow password login
    # passwd: "REPLACE_WITH_HASHED_PASSWORD"
    # lock_passwd: false

ssh_pwauth: false
disable_root: true

packages:
  - curl
  - vim
  - htop
  - git
  - glusterfs-client
  - unattended-upgrades
  - apt-listchanges

runcmd:
  - systemctl enable --now ssh
  - timedatectl set-timezone REPLACE_WITH_TIMEZONE
  - dpkg-reconfigure -plow unattended-upgrades

write_files:
  - path: /etc/hosts
    append: true
    content: |
      # Turing Pi cluster nodes
      REPLACE_WITH_RK1_IP    TuringPiRK1
      REPLACE_WITH_CM3_IP    TuringPICompute3
      REPLACE_WITH_CM4_IP    TuringPICompute4
